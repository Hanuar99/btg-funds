# =============================================================================
#  Flutter / Dart — .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Dart / Flutter — archivos generados por build_runner
# NO subir: son regenerados con `dart run build_runner build`
# -----------------------------------------------------------------------------
*.g.dart
*.freezed.dart
*.config.dart
*.mocks.dart

# -----------------------------------------------------------------------------
# Flutter / Pub — caché y metadatos locales
# -----------------------------------------------------------------------------
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.pub-cache/
.pub/

# -----------------------------------------------------------------------------
# Build output — generado al compilar
# -----------------------------------------------------------------------------
/build/
/coverage/

# Symbolication / Obfuscation
app.*.symbols
app.*.map.json

# -----------------------------------------------------------------------------
# Android
# -----------------------------------------------------------------------------
**/android/**/gradle-wrapper.jar
**/android/.gradle/
**/android/captures/
**/android/gradlew
**/android/gradlew.bat
**/android/local.properties
**/android/**/GeneratedPluginRegistrant.java
/android/app/debug
/android/app/profile
/android/app/release
.gradle/

# -----------------------------------------------------------------------------
# iOS
# -----------------------------------------------------------------------------
**/ios/**/*.mode1v3
**/ios/**/*.mode2v3
**/ios/**/*.moved-aside
**/ios/**/*.pbxuser
**/ios/**/*.perspectivev3
**/ios/**/*sync/
**/ios/**/.sconsign.dblite
**/ios/**/.tags*
**/ios/**/.vagrant/
**/ios/**/DerivedData/
**/ios/**/Icon?
**/ios/**/Pods/
**/ios/**/.symlinks/
**/ios/**/profile
**/ios/**/xcuserdata
**/ios/.generated/
**/ios/Flutter/App.framework
**/ios/Flutter/Flutter.framework
**/ios/Flutter/Flutter.podspec
**/ios/Flutter/Generated.xcconfig
**/ios/Flutter/ephemeral/
**/ios/Flutter/app.flx
**/ios/Flutter/app.zip
**/ios/Flutter/flutter_assets/
**/ios/Flutter/flutter_export_environment.sh
**/ios/ServiceDefinitions.json
**/ios/Runner/GeneratedPluginRegistrant.*
**/ios/Flutter/.last_build_id

# macOS
**/macos/Flutter/GeneratedPluginRegistrant.swift
**/macos/Flutter/ephemeral/

# Windows
**/windows/flutter/generated_plugin_registrant.cc
**/windows/flutter/generated_plugin_registrant.h
**/windows/flutter/generated_plugins.cmake
**/windows/flutter/ephemeral/

# Linux
**/linux/flutter/generated_plugin_registrant.cc
**/linux/flutter/generated_plugin_registrant.h
**/linux/flutter/generated_plugins.cmake
**/linux/flutter/ephemeral/

# Web — generado automáticamente
**/web/flutter_service_worker.js
**/web/flutter_bootstrap.js

# -----------------------------------------------------------------------------
# IDEs y editores
# -----------------------------------------------------------------------------
# IntelliJ / Android Studio
*.iml
*.ipr
*.iws
.idea/

# VS Code — mantener configuración del equipo si se desea
# .vscode/   ← descomentarlo si no quieres subir las configs de VS Code

# -----------------------------------------------------------------------------
# Sistema operativo
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db
*.swp
*.swo
*.log
*.class
*.pyc
.history
.atom/
.svn/

# -----------------------------------------------------------------------------
# Secretos y variables de entorno — NUNCA subir
# -----------------------------------------------------------------------------
.env
.env.*
*.keystore
*.jks
google-services.json
GoogleService-Info.plist
secrets.dart
firebase_options.dart

# -----------------------------------------------------------------------------
# VS Code — archivos de configuración local (no relevantes para el evaluador)
# -----------------------------------------------------------------------------
.agents/
skills-lock.json
AGENTS.md
.github/
# .vscode/   ← descomentarlo si no quieres subir las configs de VS Code

# -----------------------------------------------------------------------------
# Flutter — metadatos del proyecto (generados por el IDE)
# -----------------------------------------------------------------------------
.metadata

# -----------------------------------------------------------------------------
# Miscelánea
# -----------------------------------------------------------------------------
migrate_working_dir/
.buildlog/
.swiftpm/


